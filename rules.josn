[
  {
    "id": 1,
    "priority": 1,
    "action": { "type": "block" },
    "condition": {
      "urlFilter": "*://*.google-analytics.com/*",
      "resourceTypes": ["script", "xmlhttprequest", "ping"]
    }
  },
  {
    "id": 2,
    "priority": 1,
    "action": { "type": "block" },
    "condition": {
      "urlFilter": "*://*.doubleclick.net/*",
      "resourceTypes": ["script", "image", "sub_frame"]
    }
  },
  {
    "id": 3,
    "priority": 1,
    "action": { "type": "block" },
    "condition": {
      "urlFilter": "*://connect.facebook.net/*",
      "resourceTypes": ["script"]
    }
  }
]
